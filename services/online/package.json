{
  "name": "@clawcollect/online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply clawcollect-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply clawcollect-db --remote",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "smoke:roles": "node scripts/smoke-roles.mjs",
    "smoke:e2e": "node scripts/smoke-e2e.mjs"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
