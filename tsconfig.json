{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "../openclaw-shoppilot/node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk": [
        "../openclaw-shoppilot/node_modules/openclaw/dist/plugin-sdk/index.d.ts"
      ],
      "openclaw": [
        "../openclaw-shoppilot/node_modules/openclaw"
      ],
      "openclaw/*": [
        "../openclaw-shoppilot/node_modules/openclaw/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
