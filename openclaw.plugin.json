{
  "id": "clawcollect",
  "name": "ClawCollect",
  "description": "Collect chat replies into checklists, reminders, and routed summaries.",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "capture": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "autoExtractMessages": {
            "type": "boolean"
          },
          "onlyWhenCollectionOpen": {
            "type": "boolean"
          },
          "storeRawOutsideCollection": {
            "type": "boolean"
          }
        }
      },
      "reminders": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "sweepIntervalSec": {
            "type": "integer",
            "minimum": 15
          },
          "messageTemplate": {
            "type": "string"
          },
          "maxDeliveryAttempts": {
            "type": "integer",
            "minimum": 1
          },
          "retryBackoffSec": {
            "type": "integer",
            "minimum": 15
          }
        }
      },
      "timezone": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "default": {
            "type": "string"
          },
          "bySender": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "byScope": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "byChannel": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "intro": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "text": {
            "type": "string"
          }
        }
      },
      "adapters": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["openclaw_message", "command", "noop"]
            },
            "enabled": {
              "type": "boolean"
            },
            "description": {
              "type": "string"
            },
            "argv": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "profiles": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string"
            },
            "endpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "adapterId": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "presentationId": {
                    "type": "string"
                  },
                  "targetRef": {
                    "type": "string",
                    "enum": ["origin_scope"]
                  },
                  "channel": {
                    "type": "string"
                  },
                  "target": {
                    "type": "string"
                  },
                  "accountId": {
                    "type": "string"
                  },
                  "argv": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "audiences": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["profiles", "literal", "none"]
                },
                "description": {
                  "type": "string"
                },
                "presentationId": {
                  "type": "string"
                },
                "profileIds": {
                  "type": "array",
              "items": {
                "type": "string"
              }
            },
            "endpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "adapterId": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "presentationId": {
                    "type": "string"
                  },
                  "targetRef": {
                    "type": "string",
                    "enum": ["origin_scope"]
                  },
                  "channel": {
                    "type": "string"
                  },
                  "target": {
                    "type": "string"
                  },
                  "accountId": {
                    "type": "string"
                  },
                  "argv": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "presentations": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "template": {
              "type": "string"
            },
            "header": {
              "type": "string"
            },
            "footer": {
              "type": "string"
            },
            "linePrefix": {
              "type": "string"
            },
            "separator": {
              "type": "string"
            }
          }
        }
      },
      "events": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "effects": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "kind": {
                    "type": "string"
                  },
                  "enabled": {
                    "type": "boolean"
                  },
                  "presentationId": {
                    "type": "string"
                  },
                  "audienceIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "audiences": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "kind": {
                          "type": "string",
                          "enum": ["profiles", "literal", "none"]
                        },
                        "description": {
                          "type": "string"
                        },
                        "presentationId": {
                          "type": "string"
                        },
                        "profileIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "endpoints": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                              "adapterId": {
                                "type": "string"
                              },
                              "description": {
                                "type": "string"
                              },
                              "presentationId": {
                                "type": "string"
                              },
                              "targetRef": {
                                "type": "string",
                                "enum": ["origin_scope"]
                              },
                              "channel": {
                                "type": "string"
                              },
                              "target": {
                                "type": "string"
                              },
                              "accountId": {
                                "type": "string"
                              },
                              "argv": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "policy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["enforce", "warn"]
          },
          "allowBoundaries": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["informational", "reminder_only", "organizational", "sensitive", "transactional"]
            }
          },
          "blockBoundaries": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["informational", "reminder_only", "organizational", "sensitive", "transactional"]
            }
          },
          "requireApprovalBoundaries": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["informational", "reminder_only", "organizational", "sensitive", "transactional"]
            }
          }
        }
      },
      "onboarding": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "channel": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "introText": {
            "type": "string"
          }
        }
      },
      "storage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "filePath": {
            "type": "string"
          }
        }
      },
      "online": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "apiUrl": {
            "type": "string"
          },
          "apiToken": {
            "type": "string"
          }
        }
      }
    }
  },
  "uiHints": {
    "capture.autoExtractMessages": {
      "label": "Auto-extract messages"
    },
    "capture.onlyWhenCollectionOpen": {
      "label": "Only capture when a collection is open"
    },
    "reminders.sweepIntervalSec": {
      "label": "Reminder sweep interval (sec)"
    },
    "intro.text": {
      "label": "Intro text"
    },
    "adapters": {
      "label": "Adapters"
    },
    "profiles": {
      "label": "Profiles"
    },
    "audiences": {
      "label": "Audiences"
    },
    "events": {
      "label": "Event routes"
    },
    "policy": {
      "label": "Policy"
    },
    "onboarding.enabled": {
      "label": "Legacy intro route"
    },
    "onboarding.channel": {
      "label": "Legacy onboarding channel"
    },
    "onboarding.target": {
      "label": "Legacy onboarding target"
    },
    "onboarding.accountId": {
      "label": "Legacy onboarding account id"
    },
    "onboarding.introText": {
      "label": "Legacy intro text"
    },
    "storage.filePath": {
      "label": "Store file path",
      "placeholder": "~/.openclaw/plugins/clawcollect/store.json"
    }
  }
}
